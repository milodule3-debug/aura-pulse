{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aura Pulse",
  "version": "0.3.0",
  "identifier": "io.aura.pulse",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AURA PULSE",
        "dragDropEnabled": false,
        "width": 1500,
        "height": 940,
        "minWidth": 1080,
        "minHeight": 680,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
